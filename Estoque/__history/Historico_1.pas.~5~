unit Historico_1;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Data.DB, Vcl.Grids, Vcl.DBGrids;

type
  THistorico = class(TForm)
    dbgHistorico: TDBGrid;
    procedure FormShow(Sender: TObject);
  private
    { Private declarations }
    FID: Integer;
  public
    { Public declarations }
    property ID: Integer read FID Write FID;
  end;

var
  Historico: THistorico;

implementation

{$R *.dfm}

uses
  DM_Historico_1;

procedure THistorico.FormShow(Sender: TObject);
begin
  DM_historico.qry_historico.Close;
  DM_historico.qry_historico.Parambyname('ID').AsInteger := FID;
  DM_historico.qry_historico.Open;
end;

end.
