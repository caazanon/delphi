unit unitLogin;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.Buttons, UnitConta;

type
  TfrmLogin = class(TForm)
    edtIdentificador: TEdit;
    lblIdentificador: TLabel;
    btnEntrar: TBitBtn;
    btnCriar: TBitBtn;
    procedure edtIdentificadorExit(Sender: TObject);
    procedure btnEntrarClick(Sender: TObject);
    procedure btnCriarClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure edtIdentificadorKeyPress(Sender: TObject; var Key: Char);
  private
    FGerenciadorContas: TGerenciadorContas;
    FContaAutenticada: TConta;
    function ValidarConta: Boolean;
  public
    property ContaAutenticada: TConta read FContaAutenticada;
    property GerenciadorContas: TGerenciadorContas read FGerenciadorContas;
  end;

var
  frmLogin: TfrmLogin;

implementation

{$R *.dfm}

procedure TfrmLogin.FormCreate(Sender: TObject);
begin
  FGerenciadorContas := TGerenciadorContas.Create;
  FContaAutenticada := nil;
end;

procedure TfrmLogin.FormDestroy(Sender: TObject);
begin
  FGerenciadorContas.Free;
end;

procedure TfrmLogin.edtIdentificadorExit(Sender: TObject);
var
  LTexto: string;
begin
  // Valida se ja existe a conta quando o campo perde o foco
  btnEntrar.Enabled := False;
  btnCriar.Enabled := False;
  
  LTexto := Trim(edtIdentificador.Text);
  if LTexto = '' then
    Exit;

  if ValidarConta then
    btnEntrar.Enabled := True
  else
    btnCriar.Enabled := True;
end;

procedure TfrmLogin.edtIdentificadorKeyPress(Sender: TObject; var Key: Char);
begin
  if (Key = VK_RETURN) or (Key = VK_TAB) then
    if ValidarConta then
      btnEntrar.Enabled := True
    else
      btnCriar.Enabled := True;
end;

function TfrmLogin.ValidarConta: Boolean;
var
  LIdentificador: string;
begin
  Result := False;
  LIdentificador := Trim(edtIdentificador.Text);
  
  if LIdentificador = '' then
    Exit;
    
  if FGerenciadorContas.ContaExiste(LIdentificador) then
  begin
    FContaAutenticada := FGerenciadorContas.BuscarConta(LIdentificador);
    Result := True;
  end;
end;

procedure TfrmLogin.btnEntrarClick(Sender: TObject);
var
  LIdentificador: string;
begin
  LIdentificador := Trim(edtIdentificador.Text);
  
  if LIdentificador = '' then
  begin
    ShowMessage('Digite o identificador da conta!');
    edtIdentificador.SetFocus;
    Exit;
  end;
  
  ModalResult := mrOk;
end;

procedure TfrmLogin.btnCriarClick(Sender: TObject);
var
  LConta: TConta;
  LIdentificador: string;
begin
  LIdentificador := Trim(edtIdentificador.Text);
  
  if LIdentificador = '' then
  begin
    ShowMessage('Digite um identificador para criar a conta!');
    edtIdentificador.SetFocus;
    Exit;
  end;
  
  if FGerenciadorContas.ContaExiste(LIdentificador) then
  begin
    ShowMessage('Ja existe uma conta com este identificador! Use Entrar.');
    Exit;
  end;
  
  try
    LConta := FGerenciadorContas.CriarConta(LIdentificador, 0);
    FContaAutenticada := LConta;
    ShowMessage('Conta criada com sucesso!' + #13#10 + 
      'Identificador: ' + LConta.Identificador + #13#10 + 
      'Saldo inicial: R$ 0,00');
    btnEntrar.Enabled := True;
    btnCriar.Enabled := False;
    ModalResult := mrOk;
  except
    on E: Exception do
      ShowMessage('Erro ao criar conta: ' + E.Message);
  end;
end;

end.
