program SisCaixa;

uses
  Vcl.Forms,
  UnitOperacao in 'unitOperacao.pas' {frmOperacao},
  UnitEstrategiaSaque in 'UnitEstrategiaSaque.pas',
  UnitInventario in 'UnitInventario.pas',
  unitLogin in 'unitLogin.pas' {frmLogin},
  UnitConta in 'UnitConta.pas',
  UnitNotificacao in 'UnitNotificacao.pas';

{$R *.res}

begin
  Application.Initialize;
  Application.MainFormOnTaskbar := True;
  frmLogin := TfrmLogin.Create(nil);
  try
    if frmLogin.ShowModal = mrOk then
    begin
      Application.CreateForm(TfrmOperacao, frmOperacao);
      frmOperacao.Conta := frmLogin.ContaAutenticada;
      Application.Run;
    end;
  finally
    frmLogin.Free;
  end;
end.
