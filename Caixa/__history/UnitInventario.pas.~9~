unit UnitInventario;

interface

uses
  System.SysUtils, System.Generics.Collections;

type
  /// <summary>
  /// Representa uma denominaçăo de cédula ou moeda
  /// </summary>
  TDenominacao = record
    Valor: Currency;
    Quantidade: Integer;

    function ToString: string;
  end;

  /// <summary>
  /// Classe responsável pela gestăo do inventário de cédulas e moedas
  /// Suporta adiçăo/remoçăo dinâmica de denominaçőes
  /// </summary>
  TInventario = class
  private
    FCaixa: TDictionary<Currency, Integer>;

    function GetValorTotal: Currency;
    function GetValores(AValor: Currency): Integer;
    procedure SetCaixa(AValor: Currency; AQuantidade: Integer);

  public
    constructor Create;
    destructor Destroy; override;

    procedure AdicionarCaixa(AValor: Currency; AQuantidade: Integer);
    function RemoverCaixa(AValor: Currency; AQuantidade: Integer): Boolean;
    function ObterCaixa: TArray<TDenominacao>;

  end;

implementation

{ TDenominacao }

function TDenominacao.ToString: string;
begin
  Result := Format('R$ %s: %d', [FormatFloat('0.00', Valor), Quantidade]);
end;

{ TInventario }

constructor TInventario.Create;
begin
  inherited Create;
  FCaixa := TDictionary<Currency, Integer>.Create;
end;

destructor TInventario.Destroy;
begin
  FCaixa.Free;
  inherited Destroy;
end;

function TInventario.GetValorTotal: Currency;
var
  LPair: TPair<Currency, Integer>;
begin
  Result := 0;
  for LPair in FCaixa do
    Result := Result + (LPair.Key * LPair.Value);
end;

function TInventario.GetValores(AValor: Currency): Integer;
begin
  if not FCaixa.TryGetValue(AValor, Result) then
    Result := 0;
end;

procedure TInventario.SetCaixa(AValor: Currency; AQuantidade: Integer);
begin
  if AQuantidade <= 0 then
    FCaixa.Remove(AValor)
  else
    FCaixa.AddOrSetValue(AValor, AQuantidade);
end;

procedure TInventario.AdicionarCaixa(AValor: Currency; AQuantidade: Integer);
var
  LQuantidadeAtual: Integer;
begin
  if AQuantidade <= 0 then
    raise Exception.Create('Quantidade deve ser maior que zero');

  if AValor <= 0 then
    raise Exception.Create('Valor deve ser maior que zero');

  if FCaixa.TryGetValue(AValor, LQuantidadeAtual) then
    FCaixa[AValor] := LQuantidadeAtual + AQuantidade
  else
    FCaixa.Add(AValor, AQuantidade);
end;

function TInventario.RemoverCaixa(AValor: Currency; AQuantidade: Integer): Boolean;
var
  LQuantidadeAtual: Integer;
begin
  Result := False;

  if AQuantidade <= 0 then
    raise Exception.Create('Quantidade deve ser maior que zero');

  if not FCaixa.TryGetValue(AValor, LQuantidadeAtual) then
    Exit;

  if LQuantidadeAtual < AQuantidade then
    Exit;

  if LQuantidadeAtual = AQuantidade then
    FCaixa.Remove(AValor)
  else
    FCaixa[AValor] := LQuantidadeAtual - AQuantidade;

  Result := True;
end;

function TInventario.ObterCaixa: TArray<TDenominacao>;
var
  LList: TList<TDenominacao>;
  LPair: TPair<Currency, Integer>;
  LDenom: TDenominacao;
begin
  LList := TList<TDenominacao>.Create;
  try
    for LPair in FCaixa do
    begin
      LDenom.Valor := LPair.Key;
      LDenom.Quantidade := LPair.Value;
      LList.Add(LDenom);
    end;

    // Ordena por valor decrescente
    LList.Sort(TComparer<TDenominacao>.Construct(
      function(const Left, Right: TDenominacao): Integer
      begin
        if Left.Valor > Right.Valor then
          Result := -1
        else if Left.Valor < Right.Valor then
          Result := 1
        else
          Result := 0;
      end));

    Result := LList.ToArray;
  finally
    LList.Free;
  end;
end;
